{
  "name": "trishula",
  "version": "0.1.0",
  "description": "AI-powered job search pipeline as a Chrome/Firefox browser extension. Evaluates job offers A-F, generates ATS-safe CVs, tracks applications. Ported from career-ops.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "npm run modes:bundle && wxt build",
    "build:firefox": "npm run modes:bundle && wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "modes:bundle": "node scripts/bundle-modes.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "dompurify": "^3.2.3",
    "framer-motion": "^12.23.24",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.4",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.1",
    "tailwind-variants": "^2.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.0.287",
    "@types/dompurify": "^3.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@wxt-dev/module-react": "^1.1.3",
    "eslint": "^9.17.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4",
    "wxt": "^0.20.20"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
